# ══════════════════════════════════════════════════════
# OutReach CRM — Monorepo Environment Variables
# ══════════════════════════════════════════════════════
#
# Copy this file to .env.local at the REPO ROOT.
# apps/web reads its .env from apps/web/.env.local,
# but you can also place a root .env.local and Next.js
# will pick it up when running from apps/web (via the
# workspace scripts in the root package.json).
#
# For production, set these in your hosting provider
# (Vercel, Railway, etc.) — never commit real values.
# ══════════════════════════════════════════════════════


# ── Database (Supabase) ─────────────────────────────────
# Project URL from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string for better-auth (Supabase → Project Settings → Database)
# Example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres


# ── Auth (better-auth) ──────────────────────────────────
# Public base URL of the app — used for trusted origins & password-reset links
# Development : http://localhost:3000
# Production  : https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used by better-auth to sign sessions (min 32 chars)
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string


# ── Email — Resend ──────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Verified sender address in your Resend account
# Format: "Display Name <email@yourdomain.com>"
RESEND_FROM_EMAIL=OutReach CRM <noreply@yourdomain.com>

# Webhook signing secret from https://resend.com/webhooks
# Used to verify incoming email-event webhooks (delivered, opened, clicked, bounced)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx


# ── File Storage ────────────────────────────────────────
# Uncomment and fill in when cloud storage is wired up.

# --- AWS S3 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=outreach-crm-uploads

# --- Cloudflare R2 (S3-compatible) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=outreach-crm-uploads
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
