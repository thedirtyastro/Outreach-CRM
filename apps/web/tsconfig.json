{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@outreach/shared": ["../../packages/shared/src/index.ts"],
      "@outreach/shared/*": ["../../packages/shared/src/*"],
      "@outreach/database": ["../../packages/database/src/index.ts"],
      "@outreach/database/*": ["../../packages/database/src/*"],
      "@outreach/server": ["../../packages/server/src/index.ts"],
      "@outreach/server/*": ["../../packages/server/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
