# ══════════════════════════════════════════════════════
# apps/web — Next.js Environment Variables
# ══════════════════════════════════════════════════════
# Copy to apps/web/.env.local for local development,
# or set these in your Vercel / Railway project settings.
# ══════════════════════════════════════════════════════


# ── Database (Supabase) ─────────────────────────────────
# Consumed by @outreach/database (packages/database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string for better-auth
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres


# ── Auth ────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are exposed to the browser bundle
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — signs better-auth sessions (min 32 chars)
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string


# ── Email — Resend ──────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=OutReach CRM <noreply@yourdomain.com>
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx


# ── File Storage ────────────────────────────────────────
# Uncomment when you add cloud storage (see packages/server/src/services/attachment.service.ts)

# --- AWS S3 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=outreach-crm-uploads

# --- Cloudflare R2 ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=outreach-crm-uploads
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
