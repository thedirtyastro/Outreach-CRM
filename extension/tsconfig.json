{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["popup.ts", "content.ts", "background.ts"],
  "exclude": ["node_modules", "dist"]
}
